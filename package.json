{
  "name": "lionclaw",
  "version": "2.1.1",
  "description": "Personal AI assistant desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "typecheck:main": "tsc --noEmit -p electron/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p src/tsconfig.json",
    "build:mcps": "node scripts/build-all-mcps.js",
    "build:excalidraw-bundle": "esbuild scripts/excalidraw-entry.js --bundle --outfile=resources/excalidraw-bundle.js --format=iife --global-name=ExcalidrawBundle --define:process.env.NODE_ENV=\\\"production\\\" --minify",
    "postinstall": "npm run build:mcps",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "LionLabs",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/sdk": "^0.78.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@google/genai": "^1.45.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3": "^7.4.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react-window": "^1.8.8",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.1.0",
    "cohere-ai": "^7.20.0",
    "cron-parser": "^5.5.0",
    "csv-parse": "^6.2.1",
    "d3": "^7.9.0",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "googleapis": "^171.4.0",
    "js-tiktoken": "^1.0.21",
    "jsdom": "^24.1.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-window": "^1.8.11",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7",
    "turndown": "^7.2.4",
    "unpdf": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
